# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored and will not be committed.

wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"

# Required for ESPHome native API (example.yaml, example_api_battery.yaml)
esphome_api_key: "generate_with_esphome_config"

# Required for MQTT examples (example_mqtt_battery.yaml)
mqtt_broker: "192.168.1.x"
mqtt_username: "your_mqtt_user"      # optional, remove from config if not needed
mqtt_password: "your_mqtt_password"  # optional
